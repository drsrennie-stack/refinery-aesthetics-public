<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Botox Party Inquiry | Refinery Aesthetics</title>

  <meta name="description" content="Inquire about hosting a private Botox party with Refinery Aesthetics. We come to you. You bring the champagne." />
  <meta property="og:title" content="Host a Botox Party | Refinery Aesthetics" />
  <meta property="og:description" content="A private, luxury in-home treatment experience for you and your closest friends. We bring the expertise. You bring the champagne." />
  <meta property="og:type" content="website" />
  <meta name="robots" content="noindex" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --dark:    #1a1a1a;
      --gold:    #c8a96e;
      --gold-lt: #e2cfa5;
      --cream:   #f0ebe3;
      --tan:     #e0d6c8;
      --white:   #faf8f4;
      --muted:   #7a7168;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    html, body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      max-width: 100% !important;
      overflow-x: hidden !important;
    }

    body {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      background: var(--dark);
      color: var(--white);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ── BACKGROUND ──────────────────────────────────────────────── */
    .bg-layer {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background:
        radial-gradient(ellipse 80% 55% at 50% -5%,  rgba(200,169,110,0.16) 0%, transparent 65%),
        radial-gradient(ellipse 50% 45% at 10% 110%, rgba(200,169,110,0.07) 0%, transparent 55%),
        radial-gradient(ellipse 40% 40% at 90% 110%, rgba(200,169,110,0.07) 0%, transparent 55%);
    }

    /* ── PAGE ────────────────────────────────────────────────────── */
    .page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 64px 32px 72px;
      width: 100vw !important;
      left: 50% !important;
      margin-left: -50vw !important;
    }

    /* ── LOGO ────────────────────────────────────────────────────── */
    .logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      margin-bottom: 52px;
      text-decoration: none;
    }
    .logo-word {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(26px, 4vw, 38px);
      font-weight: 300;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1;
    }
    .logo-rule {
      width: 36px;
      height: 1px;
      background: var(--gold);
      opacity: 0.65;
      margin: 6px 0;
    }
    .logo-sub {
      font-family: 'Jost', sans-serif;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: var(--gold);
    }

    /* ── CARD ────────────────────────────────────────────────────── */
    .card {
      width: 100%;
      max-width: 560px;
      text-align: center;
    }

    .eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
    }
    .eyebrow::before, .eyebrow::after {
      content: '';
      display: block;
      width: 28px;
      height: 1px;
      background: var(--gold);
      opacity: 0.45;
    }

    .headline {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(42px, 7vw, 68px);
      font-weight: 300;
      line-height: 1.05;
      color: var(--white);
      margin-bottom: 10px;
      letter-spacing: -0.01em;
    }
    .headline em {
      font-style: italic;
      color: var(--gold-lt);
    }

    .subhead {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(18px, 3vw, 26px);
      font-weight: 300;
      font-style: italic;
      color: var(--gold);
      margin-bottom: 32px;
      letter-spacing: 0.02em;
      line-height: 1.3;
    }

    .rule {
      width: 44px;
      height: 1px;
      background: var(--gold);
      opacity: 0.45;
      margin: 0 auto 28px;
    }

    .body-copy {
      font-size: clamp(14px, 1.8vw, 15.5px);
      font-weight: 300;
      line-height: 1.9;
      color: rgba(250,248,244,0.72);
      max-width: 440px;
      margin: 0 auto 44px;
      letter-spacing: 0.02em;
    }

    /* ── WHAT TO EXPECT STRIP ────────────────────────────────────── */
    .expect-strip {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      flex-wrap: wrap;
      margin-bottom: 44px;
      border: 1px solid rgba(200,169,110,0.18);
      padding: 28px 0;
    }

    .expect-item {
      text-align: center;
      padding: 0 28px;
      position: relative;
    }

    .expect-item + .expect-item::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 32px;
      background: rgba(200,169,110,0.2);
    }

    .expect-label {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 6px;
    }

    .expect-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 15px;
      font-weight: 300;
      color: rgba(250,248,244,0.72);
      letter-spacing: 0.03em;
    }

    /* ── FORM ────────────────────────────────────────────────────── */
    #party-form {
      max-width: 480px;
      margin: 0 auto 8px;
      text-align: left;
    }

    #party-form .kajabi-subscribe-form,
    #party-form form {
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      box-shadow: none !important;
    }
    #party-form .form-title,
    #party-form h1, #party-form h2, #party-form h3,
    #party-form label { display: none !important; }

    #party-form input[type="text"],
    #party-form input[type="email"],
    #party-form input[type="tel"],
    #party-form input[type="number"],
    #party-form input:not([type="submit"]):not([type="checkbox"]):not([type="radio"]),
    #party-form textarea {
      background: rgba(250,248,244,0.05) !important;
      border: 1px solid rgba(200,169,110,0.3) !important;
      border-radius: 0 !important;
      padding: 15px 20px !important;
      font-family: 'Jost', sans-serif !important;
      font-size: 13.5px !important;
      font-weight: 300 !important;
      color: var(--white) !important;
      outline: none !important;
      width: 100% !important;
      -webkit-appearance: none !important;
      margin-bottom: 10px !important;
      box-shadow: none !important;
    }
    #party-form input::placeholder,
    #party-form textarea::placeholder { color: rgba(250,248,244,0.28) !important; }
    #party-form input:focus,
    #party-form textarea:focus {
      border-color: rgba(200,169,110,0.65) !important;
      outline: none !important;
      box-shadow: none !important;
    }
    #party-form input[type="submit"],
    #party-form button[type="submit"],
    #party-form .kajabi-button,
    #party-form [class*="submit"],
    #party-form [class*="Subscribe"],
    #party-form [class*="subscribe"] {
      background: var(--gold) !important;
      color: var(--dark) !important;
      border: 1px solid var(--gold) !important;
      border-radius: 0 !important;
      padding: 16px 24px !important;
      font-family: 'Jost', sans-serif !important;
      font-size: 11px !important;
      font-weight: 500 !important;
      letter-spacing: 0.22em !important;
      text-transform: uppercase !important;
      cursor: pointer !important;
      width: 100% !important;
      margin-top: 4px !important;
      transition: background 0.25s !important;
      -webkit-appearance: none !important;
      box-shadow: none !important;
    }
    #party-form input[type="submit"]:hover,
    #party-form button[type="submit"]:hover {
      background: var(--gold-lt) !important;
      border-color: var(--gold-lt) !important;
    }
    #party-form .form-confirmation,
    #party-form .confirmation-message,
    #party-form [class*="success"],
    #party-form [class*="confirm"] {
      font-family: 'Jost', sans-serif !important;
      font-size: 13px !important;
      font-weight: 300 !important;
      color: var(--gold) !important;
      letter-spacing: 0.08em !important;
      background: transparent !important;
      border: none !important;
      padding: 16px 0 !important;
      text-align: center !important;
    }

    /* ── HIDE RECAPTCHA ──────────────────────────────────────────── */
    .grecaptcha-badge { visibility: hidden !important; }

    /* ── PROMISE ─────────────────────────────────────────────────── */
    .promise {
      margin-top: 16px;
      font-size: 10.5px;
      font-weight: 300;
      letter-spacing: 0.14em;
      color: rgba(250,248,244,0.32);
      text-transform: uppercase;
      text-align: center;
    }

    /* ── SOCIAL ──────────────────────────────────────────────────── */
    .social {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      margin-top: 52px;
    }
    .social a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border: 1px solid rgba(200,169,110,0.22);
      border-radius: 50%;
      color: rgba(250,248,244,0.30);
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s;
    }
    .social a:hover {
      border-color: rgba(200,169,110,0.55);
      color: var(--gold);
    }

    .copyright {
      margin-top: 28px;
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.16em;
      color: rgba(250,248,244,0.22);
      text-transform: uppercase;
      text-align: center;
    }

    /* ── ANIMATIONS ──────────────────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .logo         { animation: fadeUp 0.8s ease 0.1s  both; }
    .eyebrow      { animation: fadeUp 0.7s ease 0.2s  both; }
    .headline     { animation: fadeUp 0.9s ease 0.28s both; }
    .subhead      { animation: fadeUp 0.8s ease 0.36s both; }
    .rule         { animation: fadeUp 0.6s ease 0.42s both; }
    .body-copy    { animation: fadeUp 0.8s ease 0.48s both; }
    .expect-strip { animation: fadeUp 0.7s ease 0.55s both; }
    #party-form   { animation: fadeUp 0.8s ease 0.62s both; }
    .promise      { animation: fadeUp 0.6s ease 0.70s both; }
    .social       { animation: fadeUp 0.6s ease 0.76s both; }
    .copyright    { animation: fadeUp 0.5s ease 0.80s both; }

    @media (max-width: 500px) {
      .page { padding: 48px 24px 60px; }
      .expect-strip { flex-direction: column; gap: 16px; }
      .expect-item + .expect-item::before { display: none; }
    }
  </style>
</head>
<body>

  <div class="bg-layer"></div>

  <div class="page">

    <a href="https://www.refineryaestheticswi.com" class="logo">
      <span class="logo-word">Refinery</span>
      <div class="logo-rule"></div>
      <span class="logo-sub">Aesthetics</span>
    </a>

    <div class="card">

      <p class="eyebrow">Mobile Services</p>

      <h1 class="headline">You host.<br>We <em>arrive.</em></h1>
      <p class="subhead">The Refinery Botox Party</p>
      <div class="rule"></div>

      <p class="body-copy">A private, luxury in-home treatment experience for you and your closest friends. Tell us a little about what you have in mind and we will be in touch to make it happen.</p>

      <div class="expect-strip">
        <div class="expect-item">
          <p class="expect-label">Group Size</p>
          <p class="expect-value">4 guests or more</p>
        </div>
        <div class="expect-item">
          <p class="expect-label">Service Area</p>
          <p class="expect-value">Central &amp; Northern WI</p>
        </div>
        <div class="expect-item">
          <p class="expect-label">You provide</p>
          <p class="expect-value">The champagne</p>
        </div>
      </div>

      <p style="font-size:11.5px;font-weight:300;letter-spacing:0.08em;color:rgba(250,248,244,0.45);text-align:center;margin-bottom:36px;">
        Serving Central and Northern Wisconsin. Happy to travel beyond our primary service area for a travel fee — just mention your location in the form.
      </p>

      <div id="party-form">
        <script src="https://www.refineryaestheticswi.com/forms/2149550572/embed.js"></script>
      </div>

      <p class="promise">We will be in touch within 48 hours &nbsp;·&nbsp; Protected by reCAPTCHA</p>

    </div>

    <div class="social">
      <a href="https://www.instagram.com/refineryaestheticswi" aria-label="Instagram" target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href="https://www.facebook.com/RefineryAestheticsWI" aria-label="Facebook" target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
    </div>

    <p class="copyright">© 2026 Refinery Aesthetics &nbsp;·&nbsp; Bancroft, WI</p>

  </div>

  <!-- Strip Kajabi white wrapper -->
  <script>
    function stripKajabiWrapper() {
      var form = document.getElementById('party-form');
      if (!form) return;
      form.querySelectorAll('div').forEach(function(el) {
        el.style.setProperty('background', 'transparent', 'important');
        el.style.setProperty('background-color', 'transparent', 'important');
        el.style.setProperty('box-shadow', 'none', 'important');
        el.style.setProperty('border-radius', '0', 'important');
        el.style.setProperty('border', 'none', 'important');
        el.style.setProperty('padding', '0', 'important');
      });
    }
    setTimeout(stripKajabiWrapper, 500);
    setTimeout(stripKajabiWrapper, 1200);
    setTimeout(stripKajabiWrapper, 2500);
    var formEl = document.getElementById('party-form');
    if (formEl && window.MutationObserver) {
      new MutationObserver(stripKajabiWrapper).observe(formEl, { childList: true, subtree: true });
    }
  </script>

  <script>
    function sendHeight() {
      var h = document.documentElement.scrollHeight;
      window.parent.postMessage({ type: 'resize', id: 'refinery-party', height: h }, '*');
    }
    if (window.ResizeObserver) new ResizeObserver(sendHeight).observe(document.body);
    window.addEventListener('load', sendHeight);
    window.addEventListener('resize', sendHeight);
    sendHeight();
  </script>

</body>
</html>
